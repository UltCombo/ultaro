exec --no-startup-id feh --bg-scale /home/ult/workspace/ult/ultaro/images/wallpaper.jpg

#workspace_layout stacking

focus_on_window_activation focus

default_border pixel 1
#default_border none
#for_window [class="^Gnome\\-terminal$"] default_border none
# Hide title bar for stacked/tabbed containers
#font pango:monospace 0
hide_edge_borders smart

assign [instance="^vivaldi\-stable$"] tmp
#assign [class="code"] 2
#assign [class="slack"] 3
#assign [class="org.gnome.Terminal"] 4

# exec --no-startup-id "i3-msg 'workspace 1:Web; append_layout /home/ult/.i3/w1.json'; vivaldi"
