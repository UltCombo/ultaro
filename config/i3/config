set $brightnessNotification dunstify -t 1000 -h string:x-canonical-private-synchronous:brightness -h string:hlcolor:#ffffff -h int:value:$value "☀️ $value%"
bindsym XF86MonBrightnessUp exec --no-startup-id value="$(brightnessctl set +10% | grep -Pom1 '[0-9]+(?=%)')" && $brightnessNotification
bindsym XF86MonBrightnessDown exec --no-startup-id value="$(brightnessctl set 10%- | grep -Pom1 '[0-9]+(?=%)')" && $brightnessNotification
bindsym $mod+F6 exec --no-startup-id value="$(brightnessctl set +10% | grep -Pom1 '[0-9]+(?=%)')" && $brightnessNotification
bindsym $mod+F5 exec --no-startup-id value="$(brightnessctl set 10%- | grep -Pom1 '[0-9]+(?=%)')" && $brightnessNotification

set $copyLastScreenshot xclip -i -selection clipboard -t image/png "/home/ult/Pictures/Screenshots/$(ls -r /home/ult/Pictures/Screenshots/ | head -n 1)"
bindsym Print exec --no-startup-id flameshot full -p /home/ult/Pictures/Screenshots && $copyLastScreenshot
bindsym Ctrl+Print exec --no-startup-id flameshot screen -p /home/ult/Pictures/Screenshots && $copyLastScreenshot
bindsym Shift+Print exec --no-startup-id flameshot gui -p /home/ult/Pictures/Screenshots && $copyLastScreenshot

bindsym $mod+Tab workspace next
bindsym $mod+Shift+Tab workspace prev

bindsym $mod+l exec --no-startup-id loginctl lock-session && sleep 2 && xset dpms force standby
bindsym $mod+n exec --no-startup-id dunstctl history-pop
bindsym $mod+m exec --no-startup-id i3-input -P 'i3-msg '
bindsym $mod+c exec --no-startup-id xclip -o | xclip -i -selection clipboard

set $updateDNDStatus dunstctl is-paused | sed -E -e "s/false//" -e "s/true/⛔/" > /home/ult/.config/i3status/dnd
exec --no-startup-id $updateDNDStatus
bindsym $mod+Shift+d exec --no-startup-id dunstctl set-paused toggle && $updateDNDStatus && $refresh_i3status

set $openWebPrivateCommand vivaldi --incognito 'https://duckduckgo.com/?q=&t=vivaldi&kae=d&k1=-1&kaj=m&kam=osm&kak=-1&kax=-1&kaq=-1&kap=-1&kao=-1&kau=-1&k5=2&k7=282c34&kj=21252b&k9=98c379&kx=61afef'

exec --no-startup-id i3-msg 'append_layout /home/ult/.config/i3/layout.json'
exec --no-startup-id vivaldi
exec --no-startup-id sleep 5 && $openWebPrivateCommand && sleep 0.5 && i3-msg 'workspace number 1'
exec --no-startup-id code
exec --no-startup-id slack
exec --no-startup-id gnome-terminal
exec --no-startup-id nautilus
exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ 70%
exec --no-startup-id brightnessctl set $([ "$(date +%H)" -ge 20 ] && echo 70 || echo 100)%

set $webNormalMark web-normal
set $webPrivateMark web-private
# Mark first non-private browser window as web-normal.
# Don't mark web-normal if the mark already exists.
for_window [instance="^vivaldi\-stable$" title="^(?!Vivaldi|duckduckgo\.com|DuckDuckGo).+$"] exec --no-startup-id "i3-msg -t get_marks | grep -qF $webNormalMark || i3-msg '[instance=\\"^vivaldi\\\-stable$\\" title=\\"^(?!Vivaldi|duckduckgo\\\.com|DuckDuckGo).+$\\"] mark $webNormalMark, move window to workspace number 1'"
for_window [instance="^vivaldi\-stable$" title="^(duckduckgo\.com|DuckDuckGo \- .*) \- Vivaldi$"] exec --no-startup-id "i3-msg -t get_marks | grep -qF $webPrivateMark || i3-msg '[instance=\\"^vivaldi\\\-stable$\\" title=\\"^(duckduckgo\\\.com|DuckDuckGo \\\- .*) \- Vivaldi$\\"] mark $webPrivateMark, move window to workspace Private'"

# $mod+1 emulates back-and-forth for web-normal and web-private windows.
bindsym $mod+1 exec --no-startup-id "if [ \\"$(i3-msg -t get_workspaces | jq '.[] | select(.focused==true).num')\\" = 1 ]; then i3-msg '[con_mark=\\"$webNormalMark\\"] swap with mark $webPrivateMark' || { i3-msg '[con_mark=\\"$webNormalMark\\"] move window to workspace number 1'; $openWebPrivateCommand; sleep 0.5; i3-msg 'workspace number 1'; }; else i3-msg 'workspace number 1'; fi"
exec --no-startup-id "i3-msg -t subscribe -m '[\"workspace\"]' | jq --unbuffered --raw-output0 'select(.change == \"focus\" and .current.name == \"Private\") | .current.name' | xargs -0 -I'{}' i3-msg 'workspace number 1; [con_mark=\"$webNormalMark\"] swap with mark $webPrivateMark'"

# $mod+` switches to Terminal back-and-forth.
set $term Term
bindsym $mod+dead_grave exec --no-startup-id [ "$(i3-msg -t get_workspaces | jq -r '.[] | select(.focused==true).name')" = "$term" ] && i3-msg 'workspace back_and_forth' || i3-msg 'workspace $term'

for_window [instance="^gnome\-calculator$"] floating enable
for_window [instance="^gnome\-calendar$"] floating enable
for_window [instance="^nomacs$"] floating enable

